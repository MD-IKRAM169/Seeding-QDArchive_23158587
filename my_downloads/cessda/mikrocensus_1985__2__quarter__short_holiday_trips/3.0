{"id":72,"status":"PUBLISHED","uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/5.0.1","notation":"ModeOfCollection","versionNumber":"5.0.1","archived":true,"withdrawn":false,"discoverable":false,"sourceLanguage":"en","agencyId":2,"agencyName":"DDI Alliance","agencyLogo":"44332555-52c2-48f6-8827-c0548d515985.jpg","agencyLink":"http://www.ddialliance.org/","publicationDate":"2026-02-17","codes":[],"versions":[{"id":325,"status":"PUBLISHED","itemType":"SL","language":"en","publicationDate":"2019-07-02","number":"3.0.0","uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/","canonicalUri":"urn:ddi:int.ddi.cv:ModeOfCollection:3.0","title":"Mode Of Collection","definition":"The procedure, technique, or mode of inquiry used to attain the data.","notation":"ModeOfCollection","previousVersion":0,"initialVersion":325,"notes":"This vocabulary was first published by the DDI Alliance. Please see: https://ddialliance.org/controlled-vocabularies/all.","versionChanges":"","versionNotes":"","license":"CC BY","licenseName":"Creative Commons Attribution 4.0 International","licenseLink":"http://creativecommons.org/licenses/by/4.0/","licenseLogo":"a533bae9-94c6-41ae-abe5-1eb7967af988.jpg","citation":"DDI Alliance. (2019). Mode Of Collection (Version 3.0) [Controlled vocabulary]. CESSDA. urn:ddi:int.ddi.cv:ModeOfCollection:3.0.","ddiUsage":"<div> \n <a href=\"http://www.ddialliance.org/Specification/DDI-Lifecycle/3.2\">DDI 3.2</a> \n <br /> Module Name: datacollection \n</div> \n<div>\n  Element Name: \n <a href=\"http://www.ddialliance.org/Specification/DDI-Lifecycle/3.2/XMLSchema/FieldLevelDocumentation/schemas/datacollection_xsd/elements/TypeOfModeOfCollection.html\">TypeOfModeOfCollection</a> \n</div> \n<div> \n <br /> \n</div> \n<div> \n <a href=\"http://www.ddialliance.org/Specification/DDI-Codebook/2.5/\">DDI 2.5</a> \n</div> \n<div>\n  Element/Attribute Name: \n <a href=\"http://www.ddialliance.org/Specification/DDI-Codebook/2.5/XMLSchema/field_level_documentation_files/schemas/codebook_xsd/elements/collMode.html\">collMode</a> \n</div>","lastStatusChangeDate":"2020-10-01","concepts":[{"id":4976,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/cb20d17","notation":"Interview","title":"Interview","definition":"A pre-planned communication between two (or more) people - the interviewer(s) and the interviewee(s) - in which information is obtained by the interviewer(s) from the interviewee(s). If group interaction is part of the method, use \"Focus group\".","introducedInVersionId":325,"position":0,"deprecated":false,"validFrom":"2019-07-02"},{"id":4977,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/9f669a4","notation":"Interview.FaceToFace","title":"Face-to-face interview","definition":"Data collection method in which a live interviewer conducts a personal interview, presenting questions and entering the responses. Use this broader term if not CAPI or PAPI, or if not known whether CAPI/PAPI or not.","parent":"Interview","introducedInVersionId":325,"position":1,"deprecated":false,"validFrom":"2019-07-02"},{"id":5023,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/89e4fb4","notation":"Interview.FaceToFace.CAPIorCAMI","title":"Face-to-face interview: Computer-assisted (CAPI/CAMI)","definition":"Computer-assisted personal interviewing (CAPI), or computer-assisted mobile interviewing (CAMI). Data collection method in which the interviewer reads questions to the respondents from the screen of a computer, laptop, or a mobile device like tablet or smartphone, and enters the answers in the same device. The administration of the interview is managed by a specifically designed program/application.","parent":"Interview.FaceToFace","introducedInVersionId":325,"position":2,"deprecated":false,"validFrom":"2019-07-02"},{"id":5022,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/e477963","notation":"Interview.FaceToFace.PAPI","title":"Face-to-face interview: Paper-and-pencil (PAPI)","definition":"Paper-and-pencil interviewing (PAPI). The interviewer uses a traditional paper questionnaire to read the questions and enter the answers.","parent":"Interview.FaceToFace","introducedInVersionId":325,"position":3,"deprecated":false,"validFrom":"2019-07-02"},{"id":4980,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/ae68e25","notation":"Interview.Telephone","title":"Telephone interview","definition":"Interview administered on the telephone. Use this broader term if not CATI, or if not known whether CATI or not.","parent":"Interview","introducedInVersionId":325,"position":4,"deprecated":false,"validFrom":"2019-07-02"},{"id":4981,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/1498dd4","notation":"Interview.Telephone.CATI","title":"Telephone interview: Computer-assisted (CATI)","definition":"Computer-assisted telephone interviewing (CATI). The interviewer asks questions as directed by a computer, responses are keyed directly into the computer and the administration of the interview is managed by a specifically designed program.","parent":"Interview.Telephone","introducedInVersionId":325,"position":5,"deprecated":false,"validFrom":"2019-07-02"},{"id":4982,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/b0b2868","notation":"Interview.Email","title":"E-mail interview","definition":"Interviews conducted via e-mail, usually consisting of several e-mail messages that allow the discussion to continue beyond the first set of questions and answers, or the first e-mail exchange.","parent":"Interview","introducedInVersionId":325,"position":6,"deprecated":false,"validFrom":"2019-07-02"},{"id":4983,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/1af2bfa","notation":"Interview.WebBased","title":"Web-based interview","definition":"An interview conducted via the Internet. For example, interviews conducted within online forums or using web-based audio-visual technology that enables the interviewer(s) and interviewee(s) to communicate in real time.","parent":"Interview","introducedInVersionId":325,"position":7,"deprecated":false,"validFrom":"2019-07-02"},{"id":4984,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/35e4248","notation":"SelfAdministeredQuestionnaire","title":"Self-administered questionnaire","definition":"Data collection method in which the respondent reads or listens to the questions, and enters the responses by him/herself; no live interviewer is present, or participates in the questionnaire administration. If possible, use a narrower term. Use this broader term if the method is not described by any of the narrower terms - for example, for PDF and diskette questionnaires.","introducedInVersionId":325,"position":8,"deprecated":false,"validFrom":"2019-07-02"},{"id":4985,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/69a46ca","notation":"SelfAdministeredQuestionnaire.Email","title":"Self-administered questionnaire: E-mail","definition":"Self-administered survey in which questions are presented to the respondent in the text body of an e-mail or as an attachment to an e-mail, but not as a link to a web-based questionnaire. Responses are also sent back via e-mail, in the e-mail body or as an attachment.","parent":"SelfAdministeredQuestionnaire","introducedInVersionId":325,"position":9,"deprecated":false,"validFrom":"2019-07-02"},{"id":4986,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/6255fce","notation":"SelfAdministeredQuestionnaire.Paper","title":"Self-administered questionnaire: Paper","definition":"Self-administered survey using a traditional paper questionnaire delivered and/or collected by mail (postal services), by fax, or in person by either interviewer, or respondent.","parent":"SelfAdministeredQuestionnaire","introducedInVersionId":325,"position":10,"deprecated":false,"validFrom":"2019-07-02"},{"id":4987,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/ddaefe8","notation":"SelfAdministeredQuestionnaire.SMSorMMS","title":"Self-administered questionnaire: Messaging (SMS/MMS)","definition":"Self-administered survey in which the respondents receive the questions incorporated in SMS (text messages) or MMS (messages including multimedia content) and send their replies in the same format.","parent":"SelfAdministeredQuestionnaire","introducedInVersionId":325,"position":11,"deprecated":false,"validFrom":"2019-07-02"},{"id":4988,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/557586d","notation":"SelfAdministeredQuestionnaire.CAWI","title":"Self-administered questionnaire: Web-based (CAWI)","definition":"Computer-assisted web interviewing (CAWI). Data are collected using a web questionnaire, produced with a program for creating web surveys. The program can customize the flow of the questionnaire based on the answers provided, and can allow for the questionnaire to contain pictures, audio and video clips, links to different web pages etc.","parent":"SelfAdministeredQuestionnaire","introducedInVersionId":325,"position":12,"deprecated":false,"validFrom":"2019-07-02"},{"id":4989,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/e48ace5","notation":"SelfAdministeredQuestionnaire.CASI","title":"Self-administered questionnaire: Computer-assisted (CASI)","definition":"Computer-assisted self-interview (CASI). Respondents enter the responses into a computer (desktop, laptop, Palm/PDA, tablet, etc.) by themselves. The administration of the questionnaire is managed by a specifically designed program/application but there is no real-time data transfer as in CAWI, the answers are stored on the device used for the interview. The questionnaire may be fixed form or interactive. Includes VCASI (Video computer-assisted self-interviewing), ACASI (Audio computer-assisted self-interviewing) and TACASI (Telephone audio computer-assisted self-interviewing).","parent":"SelfAdministeredQuestionnaire","introducedInVersionId":325,"position":13,"deprecated":false,"validFrom":"2019-07-02"},{"id":4990,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/9ec957d","notation":"FocusGroup","title":"Focus group","definition":"A group discussion on a particular topic, organized for research purposes. The individuals are selected with relevance to the topic, and interaction among the participants is used as part of the method.","introducedInVersionId":325,"position":14,"deprecated":false,"validFrom":"2019-07-02"},{"id":4991,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/00b3692","notation":"FocusGroup.FaceToFace","title":"Face-to-face focus group","definition":"The focus group participants meet in person to conduct the discussion.","parent":"FocusGroup","introducedInVersionId":325,"position":15,"deprecated":false,"validFrom":"2019-07-02"},{"id":4992,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/2b4ef44","notation":"FocusGroup.Telephone","title":"Telephone focus group","definition":"The focus group discussion is conducted over the telephone.","parent":"FocusGroup","introducedInVersionId":325,"position":16,"deprecated":false,"validFrom":"2019-07-02"},{"id":4993,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/4da1255","notation":"FocusGroup.Online","title":"Online focus group","definition":"The focus group discussion is conducted over the Internet in an interactive manner.","parent":"FocusGroup","introducedInVersionId":325,"position":17,"deprecated":false,"validFrom":"2019-07-02"},{"id":4994,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/08e658a","notation":"SelfAdministeredWritingsAndDiaries","title":"Self-administered writings and/or diaries","definition":"Narratives, stories, diaries, and written texts created by the research subject.","introducedInVersionId":325,"position":18,"deprecated":false,"validFrom":"2019-07-02"},{"id":4995,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/fe226ad","notation":"SelfAdministeredWritingsAndDiaries.Email","title":"Self-administered writings and/or diaries: E-mail","definition":"Narratives, stories, diaries, and written texts submitted via e-mail messages.","parent":"SelfAdministeredWritingsAndDiaries","introducedInVersionId":325,"position":19,"deprecated":false,"validFrom":"2019-07-02"},{"id":4996,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/e5bef42","notation":"SelfAdministeredWritingsAndDiaries.Paper","title":"Self-administered writings and/or diaries: Paper","definition":"Narratives, stories, diaries, and written texts created and collected in paper form.","parent":"SelfAdministeredWritingsAndDiaries","introducedInVersionId":325,"position":20,"deprecated":false,"validFrom":"2019-07-02"},{"id":4997,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/9e67a7c","notation":"SelfAdministeredWritingsAndDiaries.WebBased","title":"Self-administered writings and/or diaries: Web-based","definition":"Narratives, stories, diaries, and written texts gathered from Internet sources, e.g. websites, blogs, discussion forums.","parent":"SelfAdministeredWritingsAndDiaries","introducedInVersionId":325,"position":21,"deprecated":false,"validFrom":"2019-07-02"},{"id":4998,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/c680d43","notation":"Observation","title":"Observation","definition":"Research method that involves collecting data as they occur (for example, observing behaviors, events, development of condition or disease, etc.), without attempting to manipulate any of the independent variables.","introducedInVersionId":325,"position":22,"deprecated":false,"validFrom":"2019-07-02"},{"id":4999,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/bdc4aac","notation":"Observation.Field","title":"Field observation","definition":"Observation that is conducted in a natural environment.","parent":"Observation","introducedInVersionId":325,"position":23,"deprecated":false,"validFrom":"2019-07-02"},{"id":5002,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/e679c7f","notation":"Observation.Laboratory","title":"Laboratory observation","definition":"Observation that is conducted in a controlled, artificially created setting. For example, observing children's play in a laboratory playroom.","parent":"Observation","introducedInVersionId":325,"position":24,"deprecated":false,"validFrom":"2019-07-02"},{"id":5025,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/2a58349","notation":"Observation.Laboratory.Participant","title":"Participant laboratory observation","definition":"Type of laboratory observation in which the researcher interacts with the subjects and often plays a role in the social situation under observation. For example, observing children's play in a laboratory playroom with the researcher taking part in the play.","parent":"Observation.Laboratory","introducedInVersionId":325,"position":25,"deprecated":false,"validFrom":"2019-07-02"},{"id":5005,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/40b8b0c","notation":"Observation.ComputerBased","title":"Computer-based observation","definition":"Type of observation in which data regarding computer usage are being collected by software that can be built into the computer program itself or can be a separate program. Information may be collected about the number of users, the ways in which users interact with the program(s), how much time they spend on a page, how they use specific sections of applications, how they navigate from page to page or from one application to another, etc.","parent":"Observation","introducedInVersionId":325,"position":26,"deprecated":false,"validFrom":"2019-07-02"},{"id":5024,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/3cee522","notation":"Observation.Field.Participant","title":"Participant field observation","definition":"Type of field observation in which the researcher interacts with the subjects and often plays a role in the social situation under observation.","parent":"Observation.Field","introducedInVersionId":325,"position":27,"deprecated":false,"validFrom":"2019-07-02"},{"id":5001,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/8245871","notation":"Observation.Field.Nonparticipant","title":"Non-participant field observation","definition":"Observation that is conducted in a natural, non-controlled setting without any interaction between the researcher and his/her subjects.","parent":"Observation.Field","introducedInVersionId":325,"position":28,"deprecated":false,"validFrom":"2019-07-02"},{"id":5004,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/68b02fb","notation":"Observation.Laboratory.Nonparticipant","title":"Non-participant laboratory observation","definition":"Type of laboratory observation that is conducted without any interaction between the researcher and his/her subjects.","parent":"Observation.Laboratory","introducedInVersionId":325,"position":29,"deprecated":false,"validFrom":"2019-07-02"},{"id":5006,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/05aeba4","notation":"Experiment","title":"Experiment","definition":"Research method involving the manipulation of some or all of the independent variables included in the hypotheses.","introducedInVersionId":325,"position":30,"deprecated":false,"validFrom":"2019-07-02"},{"id":5007,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/28a60a6","notation":"Experiment.Laboratory","title":"Laboratory experiment","definition":"An experiment conducted in a controlled, artificially created physical setting, in which a researcher manipulates one or several independent variables and measures its/their effect on the dependent variable.","parent":"Experiment","introducedInVersionId":325,"position":31,"deprecated":false,"validFrom":"2019-07-02"},{"id":5008,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/5ff61de","notation":"Experiment.FieldIntervention","title":"Field/Intervention experiment","definition":"An experiment conducted in a natural, uncontrolled setting, in which the researcher manipulates one or several independent variables. Intervention/clinical studies are one example of field experiments.","parent":"Experiment","introducedInVersionId":325,"position":32,"deprecated":false,"validFrom":"2019-07-02"},{"id":5009,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/ed0d083","notation":"Experiment.WebBased","title":"Web-based experiment","definition":"An experiment conducted in the virtual setting of the World Wide Web, in which experimental materials are programmed to implement artificial situations or events to be investigated in a distributed environment. (Reips, U.-D. (2002). Theory and techniques of Web experimenting. In B. Batinic, U.-D. Reips, & M. Bosnjak (Eds.), Online Social Sciences. Seattle: Hogrefe & Huber. Available at: http://www.websm.org/uploadi/editor/Reips_2002_Theory_and_techniques.pdf [07 June 2013])","parent":"Experiment","introducedInVersionId":325,"position":33,"deprecated":false,"validFrom":"2019-07-02"},{"id":5010,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/c5564d2","notation":"Recording","title":"Recording","definition":"Registering by mechanical or electronic means, in a form that allows the information to be retrieved and/or reproduced. For example, images or sounds on disc or magnetic tape.","introducedInVersionId":325,"position":34,"deprecated":false,"validFrom":"2019-07-02"},{"id":5011,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/4848ed5","notation":"ContentCoding","title":"Content coding","definition":"As a mode of secondary data collection, content coding applies coding techniques to transform qualitative data (textual, video, audio or still-image) originally produced for other purposes into quantitative data (expressed in unit-by-variable matrices) in accordance with pre-defined categorization schemes. For example, coded party manifesto data like the \"European Parliament Election Study 2009, Manifesto Study\" (doi:10.4232/1.10204).","introducedInVersionId":325,"position":35,"deprecated":false,"validFrom":"2019-07-02"},{"id":5012,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/df9aac3","notation":"Transcription","title":"Transcription","definition":"Capturing information in writing from a different source, or from a different medium, alphabet, or form of notation, like scientific formulae, or musical notes. For transcribed interviews or observations, it is recommended to document the primary mode of collection, using one of the interview or observation terms.","introducedInVersionId":325,"position":36,"deprecated":false,"validFrom":"2019-07-02"},{"id":5013,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/6decc77","notation":"CompilationSynthesis","title":"Compilation/Synthesis","definition":"Collecting and assembling data from multiple, often heterogeneous sources that have one or more reference points in common, and at least one of the sources was originally produced for other purposes. The data are incorporated in a new entity. For example, providing data on the number of universities in the last 150 years using a variety of available sources (e.g. finance documents, official statistics, university registers), combining survey data with information about geographical areas from official statistics (e.g. population density, doctors per capita, etc.), or using RSS to collect blog posts or tweets, etc.","introducedInVersionId":325,"position":37,"deprecated":false,"validFrom":"2019-07-02"},{"id":5014,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/2906121","notation":"Summary","title":"Summary","definition":"Presentation of information in a condensed form, by reducing it to its main points. For example, abstracts of interviews or reports that are published and used as data rather than the full-length interviews or reports.","introducedInVersionId":325,"position":38,"deprecated":false,"validFrom":"2019-07-02"},{"id":5015,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/d9ceca6","notation":"Aggregation","title":"Aggregation","definition":"Statistics that relate to broad classes, groups, or categories. The data are averaged, totaled, or otherwise derived from individual-level data, and it is no longer possible to distinguish the characteristics of individuals within those classes, groups, or categories. For example, the number and age group of the unemployed in specific geographic regions, or national level statistics on the occurrence of specific offences, originally derived from the statistics of individual police districts.","introducedInVersionId":325,"position":39,"deprecated":false,"validFrom":"2019-07-02"},{"id":5016,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/4f502b5","notation":"Simulation","title":"Simulation","definition":"Modeling or imitative representation of real-world processes, events, or systems, often using computer programs. For example, a program modeling household consumption responses to indirect tax changes; or a dataset on hypothetical patients and their drug exposure, background conditions, and known adverse events.","introducedInVersionId":325,"position":40,"deprecated":false,"validFrom":"2019-07-02"},{"id":5017,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/38ceaa4","notation":"MeasurementsAndTests","title":"Measurements and tests","definition":"Assessing specific properties (or characteristics) of beings, things, phenomena, (and/ or processes) by applying pre-established standards and/or specialized instruments or techniques.","introducedInVersionId":325,"position":41,"deprecated":false,"validFrom":"2019-07-02"},{"id":5018,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/4b9776b","notation":"MeasurementsAndTests.Educational","title":"Educational measurements and tests","definition":"Assessment of knowledge, skills, aptitude, or educational achievement by means of specialized measures or tests.","parent":"MeasurementsAndTests","introducedInVersionId":325,"position":42,"deprecated":false,"validFrom":"2019-07-02"},{"id":5019,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/c2a25a6","notation":"MeasurementsAndTests.Physical","title":"Physical measurements and tests","definition":"Assessment of physical properties of living beings, objects, materials, or natural phenomena. For example, findings from hands-on medical examination (e.g., palpation or auscultation), clinical measurements and lab tests like blood analysis, blood pressure, heart rate, body weight and height, as well as general measurements like time, distance, mass, temperature, force, power, speed, GPS data on physical movement and other physical parameters or variables, like geospatial data.","parent":"MeasurementsAndTests","introducedInVersionId":325,"position":43,"deprecated":false,"validFrom":"2019-07-02"},{"id":5020,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/27daf03","notation":"MeasurementsAndTests.Psychological","title":"Psychological measurements and tests","definition":"Assessment of personality traits or psychological/behavioral responses by means of specialized measures or tests. For example, objective tests like self-report measures with a restricted response format, or projective methods allowing free responses, including word association, sentence or story completion, vignettes, cartoon test, thematic apperception tests, role play, drawing tests, inkblot tests, choice ordering exercises, etc.","parent":"MeasurementsAndTests","introducedInVersionId":325,"position":44,"deprecated":false,"validFrom":"2019-07-02"},{"id":5021,"uri":"http://rdf-vocabulary.ddialliance.org/cv/ModeOfCollection/3.0.0/6311ae1","notation":"Other","title":"Other","definition":"Use if the mode of data collection is known, but not found in the list.","introducedInVersionId":325,"position":45,"deprecated":false,"validFrom":"2019-07-02"}],"comments":[],"versionHistories":[]}],"titleAll":"Mode Of Collection","versionDa":"3.0.1","versionNl":"5.0.1","titleNl":"Verzamelmethode","definitionNl":"De procedure, techniek of methode die is gebruikt om de gegevens te verzamelen. ","versionEn":"5.0.1","titleEn":"Mode Of Collection","definitionEn":"The procedure, technique, or mode of inquiry used to attain the data.","versionFi":"5.0.1","titleFi":"Keruumenetelmä","definitionFi":"Kuvailtavan aineiston ensisijainen keruumenetelmä.","versionFr":"5.0.1","titleFr":"Mode de collecte","definitionFr":"La procédure, la technique ou le mode d'enquête utilisé pour obtenir les données.","versionDe":"5.0.1","titleDe":"Erhebungsmodus","definitionDe":"Prozedur, Technik oder Art der Erhebung, die verwendet wurde, um Daten zu bekommen.","versionIt":"5.0.1","titleIt":"Metodo di raccolta dei dati","definitionIt":"La procedura, la tecnica o la modalità di indagine utilizzata per ottenere i dati.","versionJa":"4.0.3","titleJa":"調査方法","definitionJa":"データを取得するにあたり利用された調査の手続き、技術あるいは方法。","versionLt":"5.0.1","titleLt":"Surinkimo būdas","definitionLt":"Tyrimo procedūra, technika ar būdas, naudojami gauti duomenis.","versionNo":"5.0.1","titleNo":"Innsamlingsmetode","definitionNo":"Framgangsmåten, teknikken, eller metoden som er anvendt for å samle inn data.","versionPt":"4.0.3","versionSr":"3.0.1","versionSl":"5.0.1","titleSl":"Način zbiranja podatkov","definitionSl":"Postopki, tehnike ali načini raziskovanja, uporabljeni za pridobivanje podatkov.","versionSv":"5.0.1","titleSv":"Insamlingsmetod","definitionSv":"Den process, metod eller teknik som användes för att samla in data."}