{"id":55,"status":"PUBLISHED","uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/2.0.2","notation":"SamplingProcedure","versionNumber":"2.0.2","archived":true,"withdrawn":false,"discoverable":false,"sourceLanguage":"en","agencyId":2,"agencyName":"DDI Alliance","agencyLogo":"44332555-52c2-48f6-8827-c0548d515985.jpg","agencyLink":"http://www.ddialliance.org/","publicationDate":"2026-02-17","codes":[],"versions":[{"id":250,"status":"PUBLISHED","itemType":"SL","language":"en","publicationDate":"2019-05-06","number":"1.1.0","uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/","canonicalUri":"urn:ddi:int.ddi.cv:SamplingProcedure:1.1","title":"Sampling Procedure","definition":"A typology of sampling methods.","notation":"SamplingProcedure","previousVersion":0,"initialVersion":250,"notes":"This vocabulary was first published by the DDI Alliance. Please see: https://ddialliance.org/controlled-vocabularies/all.","versionChanges":"","versionNotes":"","license":"CC BY","licenseName":"Creative Commons Attribution 4.0 International","licenseLink":"http://creativecommons.org/licenses/by/4.0/","licenseLogo":"a533bae9-94c6-41ae-abe5-1eb7967af988.jpg","citation":"DDI Alliance. (2019). Sampling Procedure (Version 1.1) [Controlled vocabulary]. CESSDA. urn:ddi:int.ddi.cv:SamplingProcedure:1.1. ","ddiUsage":"<p><a href=\"https://ddialliance.org/Specification/DDI-Lifecycle/3.3/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">DDI-L 3.3</a></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Module name: datacollection</span></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Element name:&nbsp;</span><a href=\"https://ddialliance.org/Specification/DDI-Lifecycle/3.3/XMLSchema/FieldLevelDocumentation/schemas/datacollection_xsd/elements/TypeOfSamplingProcedure.html\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">TypeOfSamplingProcedure</a></p><p><a href=\"https://ddialliance.org/Specification/DDI-Lifecycle/3.3/XMLSchema/FieldLevelDocumentation/schemas/datacollection_xsd/elements/TypeOfSample.html\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">TypeOfSample</a></p><p><br></p><p><a href=\"http://www.ddialliance.org/Specification/DDI-Lifecycle/3.2/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">DDI-L 3.2</a></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Module Name: datacollection</span></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Element Name:&nbsp;</span><a href=\"http://www.ddialliance.org/Specification/DDI-Lifecycle/3.2/XMLSchema/FieldLevelDocumentation/schemas/datacollection_xsd/elements/TypeOfSamplingProcedure.html\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">TypeOfSamplingProcedure</a></p><p><br></p><p><a href=\"http://www.ddialliance.org/Specification/DDI-Codebook/2.5/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">DDI-C 2.5</a></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Element/Attribute Name:&nbsp;</span><a href=\"http://www.ddialliance.org/Specification/DDI-Codebook/2.5/XMLSchema/field_level_documentation_files/schemas/codebook_xsd/elements/sampProc.html\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"color: rgb(30, 135, 240); background-color: transparent;\">sampProc</a></p><p><span style=\"color: rgb(33, 37, 41); background-color: rgb(255, 255, 255);\">Element XPath: </span><span style=\"color: rgb(0, 0, 0); background-color: rgb(255, 255, 255);\">/codeBook/stdyDscr/method/dataColl/sampProc</span></p>","lastStatusChangeDate":"2020-10-01","concepts":[{"id":1988,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/885b553","notation":"TotalUniverseCompleteEnumeration","title":"Total universe/Complete enumeration","definition":"All units (individuals, households, organizations, etc.) of a target population are included in the data collection. For example, if the target population is defined as the members of a trade union, all union members are invited to participate in the study. Also called \"census\" if the entire population of a regional unit (e.g. a country) is selected.","introducedInVersionId":250,"position":0,"deprecated":false,"validFrom":"2019-05-06"},{"id":1989,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/0d2765b","notation":"Probability","title":"Probability","definition":"All units (individuals, households, organizations, etc.) of a target population have a non-zero probability of being included in the sample and this probability can be accurately determined. Use this broader term if a more specific type of probability sampling is not known or is difficult to identify.","introducedInVersionId":250,"position":1,"deprecated":false,"validFrom":"2019-05-06"},{"id":1990,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/38e8e88","notation":"Probability.SimpleRandom","title":"Probability: Simple random","definition":"All units of a target population have an equal probability of being included in the sample. Typically, the entire population is listed in a \"sample frame\", and units are then chosen from this frame using a random selection method.","parent":"Probability","introducedInVersionId":250,"position":2,"deprecated":false,"validFrom":"2019-05-06"},{"id":1991,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/f189f62","notation":"Probability.SystematicRandom","title":"Probability: Systematic random","definition":"A fixed selection interval is determined by dividing the population size by the desired sample size. A starting point is then randomly drawn from the sample frame, which normally covers the entire target population. From this starting point, units for the sample are chosen based on the selection interval. Also known as interval sampling. For example, a company survey seeks a sample of 1,000 employees out of 10,000 total. Beginning with a random starting number, every 10th name from the employee list of the company will be invited to participate in the study.","parent":"Probability","introducedInVersionId":250,"position":3,"deprecated":false,"validFrom":"2019-05-06"},{"id":1992,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/55d038d","notation":"Probability.Stratified","title":"Probability: Stratified","definition":"The target population is subdivided into separate and mutually exclusive segments (strata) that cover the entire population. Independent random samples are then drawn from each segment. For example, in a national public opinion survey the entire population is divided into two regional strata: East and West. After this, sampling units are drawn from within each region using simple or systematic random sampling. Use this broader term if the specific type of stratified sampling is not known or difficult to identify.","parent":"Probability","introducedInVersionId":250,"position":4,"deprecated":false,"validFrom":"2019-05-06"},{"id":2006,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/7653f19","notation":"Probability.Stratified.Proportional","title":"Probability: Stratified: Proportional","definition":"The target population is subdivided into separate and mutually exclusive segments (strata) that cover the entire population. In proportional stratified sampling the number of elements chosen from each stratum is proportional to the population size of the stratum when viewed against the entire population. For example, a country is divided into two regional strata that comprise 80 percent (West) and 20 percent (East) of the total population. For a sample of 1,000 people, 800 (i.e., 80 percent) would be drawn from the West and 200 (i.e., 20 percent) from the East to accurately represent their proportion in the total population.","parent":"Probability.Stratified","introducedInVersionId":250,"position":5,"deprecated":false,"validFrom":"2019-05-06"},{"id":1994,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/2059a2b","notation":"Probability.Stratified.Disproportional","title":"Probability: Stratified: Disproportional","definition":"The target population is subdivided into separate and mutually exclusive segments (strata) that cover the entire population. In disproportional sampling the number of units chosen from each stratum is not proportional to the population size of the stratum when viewed against the entire population. The number of sampled units from each stratum can be equal, optimal, or can reflect the purpose of the study, like oversampling of different subgroups of the population. For example, a country is divided into two regional strata that comprise 80 percent (West) and 20 precent (East) of the country's population. If equal representation of the two regions is needed in a study, half the sample may be drawn from the West and half from the East, so that each region is represented by 50 percent of the sample. If a more detailed analysis of the population from the East is needed, 40 percent of the units may be drawn from the West and 60 percent from the East, so that the East is over-represented.","parent":"Probability.Stratified","introducedInVersionId":250,"position":6,"deprecated":false,"validFrom":"2019-05-06"},{"id":1995,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/1f6e5f3","notation":"Probability.Cluster","title":"Probability: Cluster","definition":"The target population is divided into naturally occurring segments (clusters) and a probability sample of the clusters is selected. Data are then collected from all units within each selected cluster. Sampling is often clustered by geography, or time period. Use this broader term if a more specific type of cluster sampling is not known or is difficult to identify.","parent":"Probability","introducedInVersionId":250,"position":7,"deprecated":false,"validFrom":"2019-05-06"},{"id":2009,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/8e08217","notation":"Probability.Cluster.SimpleRandom","title":"Probability: Cluster: Simple random","definition":"The target population is divided into naturally occurring segments (clusters) and a simple random sample of the clusters is selected. Data are then collected from all units within each selected cluster. For example, for a sample of students in a city, a number of schools would be chosen using the random selection method, and then all of the students from every sampled school would be included.","parent":"Probability.Cluster","introducedInVersionId":250,"position":8,"deprecated":false,"validFrom":"2019-05-06"},{"id":2008,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/49f4571","notation":"Probability.Cluster.StratifiedRandom","title":"Probability: Cluster: Stratified random","definition":"The target population is divided into naturally occurring segments (clusters); next, these are divided into mutually exclusive strata and a random sample of clusters is selected from each stratum. Data are then collected from all units within each selected cluster. For example, for a sample of students in a city, schools would be divided into two strata by school type (private vs. public); schools would be then randomly selected from each stratum, and all of the students from every sampled school would be included.","parent":"Probability.Cluster","introducedInVersionId":250,"position":9,"deprecated":false,"validFrom":"2019-05-06"},{"id":1998,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/f91d8ca","notation":"Probability.Multistage","title":"Probability: Multistage","definition":"Sampling is carried out in stages using smaller and smaller units at each stage, and all stages involve a probability selection. The type of probability sampling procedure may be different at each stage. For example, for a sample of students in a city, schools are randomly selected in the first stage. A random sample of classes within each selected school is drawn in the second stage. Students are then randomly selected from each of these classes in the third stage.","parent":"Probability","introducedInVersionId":250,"position":10,"deprecated":false,"validFrom":"2019-05-06"},{"id":1999,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/4d8364f","notation":"Nonprobability","title":"Non-probability","definition":"The selection of units (individuals, households, organizations, etc.) from the target population is not based on random selection. It is not possible to determine the probability of each element to be sampled. Use this broader term if the specific type of non-probability is not known, difficult to identify, or if multiple non-probability methods are being employed.","introducedInVersionId":250,"position":11,"deprecated":false,"validFrom":"2019-05-06"},{"id":2000,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/90cbfe9","notation":"Nonprobability.Availability","title":"Non-probability: Availability","definition":"The sample selection is based on the units' accessibility/relative ease of access. They may be easy to approach, or may themselves choose to participate in the study (self-selection). Researchers may have particular target groups in mind but they do not control the sample selection mechanism. For example, students leaving a particular building on campus may be approached, or individuals may volunteer to participate in response to invitations that do not target them specifically, but a larger group to which they may belong. Also called \"convenience\" or \"opportunity\" sampling.","parent":"Nonprobability","introducedInVersionId":250,"position":12,"deprecated":false,"validFrom":"2019-05-06"},{"id":2001,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/45d8ec9","notation":"Nonprobability.Purposive","title":"Non-probability: Purposive","definition":"Sample units are specifically identified, selected and contacted for the information they can provide on the researched topic. Selection is based on different characteristics of the independent and/or dependent variables under study, and relies on the researchers' judgement. The study authors, or persons authorized by them have control over the sample selection mechanism and the universe is defined in terms of the selection criteria. Also called \"judgement\" sampling. For example, a medical researcher may intentionally select individuals who are similar in most respects, except on the outcome of the research topic, which can be a specific disease. Some types of purposive sampling are typical/deviant case, homogeneous/maximum variation, expert, or critical case sampling.","parent":"Nonprobability","introducedInVersionId":250,"position":13,"deprecated":false,"validFrom":"2019-05-06"},{"id":2002,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/f620230","notation":"Nonprobability.Quota","title":"Non-probability: Quota","definition":"The target population is subdivided into separate and mutually exclusive segments according to some predefined quotation criteria. The distribution of the quotation criteria (gender/age/ethnicity ratio, or other characteristics, like religion, education, etc.) is intended to reflect the real structure of the target population or the structure of the desired study population. Non-probability samples are then drawn from each segment until a specific number of units has been reached. For example, if the target population consists of 45 percent females and 55 percent males, a proportional quota sample will have the same gender percentages, while in a non-proportional quota sample the percentages will be different, based on some study-related consideration (for instance, the need to oversample for certain under-represented segments of the population).","parent":"Nonprobability","introducedInVersionId":250,"position":14,"deprecated":false,"validFrom":"2019-05-06"},{"id":2003,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/086e080","notation":"Nonprobability.RespondentAssisted","title":"Non-probability: Respondent-assisted \t","definition":"Sample units are identified from a target population with the assistance of units already selected (adapted from \"Public Health Research Methods\", ed. Greg Guest, Emily E. Namey, 2014). A typical case is snowball sampling, in which the researcher identifies a group of units that matches a particular criterion of eligibility. The latter are asked to recruit other members of the same population that fulfil the same criterion of eligibility (sampling of specific populations like migrants, etc.).","parent":"Nonprobability","introducedInVersionId":250,"position":15,"deprecated":false,"validFrom":"2019-05-06"},{"id":2004,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/e890a15","notation":"MixedProbabilityNonprobability","title":"Mixed probability and non-probability","definition":"Sample design that combines probability and non-probability sampling within the same sampling process. Different types of sampling may be used at different stages of creating the sample. For example, for a sample of minority students in a city, schools are randomly selected in the first stage. Then, a quota sample of students is selected within each school in the second stage. If separate samples are drawn from the same target population using different sampling methods, the type of sampling procedure used for each sample should be classified separately.","introducedInVersionId":250,"position":16,"deprecated":false,"validFrom":"2019-05-06"},{"id":2005,"uri":"http://rdf-vocabulary.ddialliance.org/cv/SamplingProcedure/1.1.0/6311ae1","notation":"Other","title":"Other","definition":"Use if the sampling procedure is known, but not found in the list.","introducedInVersionId":250,"position":17,"deprecated":false,"validFrom":"2019-05-06"}],"comments":[],"versionHistories":[]}],"titleAll":"Sampling Procedure","versionNl":"2.0.2","titleNl":"Steekproefmethode","definitionNl":"Een indeling van steekproefmethodes.","versionEn":"2.0.2","titleEn":"Sampling Procedure","definitionEn":"A typology of sampling methods.","versionFi":"2.0.2","titleFi":"Otantamenetelmä","definitionFi":"Aineistossa käytetyn otantamenetelmän tyyppiluokittelu.","versionFr":"2.0.2","titleFr":"Procédure d'échantillonnage","definitionFr":"Une typologie des méthodes d'échantillonnage","versionDe":"2.0.2","titleDe":"Auswahlverfahren","definitionDe":"Enthält eine Typologie von Stichprobenverfahren.","versionIt":"2.0.2","titleIt":"Procedura di campionamento","definitionIt":"Tipologia dei metodi di campionamento.","versionJa":"2.0.2","titleJa":"サンプリング方法","definitionJa":"サンプリング方法の分類","versionLt":"2.0.2","titleLt":"Atrankos procedūra","definitionLt":"Atrankos metodų tipologija.","versionNo":"2.0.2","titleNo":"Utvalgsmetode","definitionNo":"Inneholder en typologi av ulike utvalgsmetoder.","versionPt":"1.1.4","titlePt":"Método de amostragem","definitionPt":"Tipologia de métodos de amostragem.","versionSr":"1.1.4","titleSr":"Postupak uzorkovanja","definitionSr":"Tipologija metoda uzorkovanja.","versionSl":"2.0.2","titleSl":"Postopek vzorčenja","definitionSl":"Vključuje razvrstitev metod vzorčenja.","versionSv":"2.0.2","titleSv":"Urvalsmetod","definitionSv":"Innehåller en typologi av olika urvalsmetoder."}